<UserControl x:Class="CanMonitor.Wpf.Transmit.TransmitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BackgroundBrush}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Teensy PWM Control"
                   Style="{StaticResource BodyTextStyle}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,14"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,18">
            <Button Content="ON"
                    Command="{Binding SendOnCommand}"
                    MinHeight="42"
                    Margin="0,0,8,0"/>
            <Button Content="OFF"
                    Command="{Binding SendOffCommand}"
                    MinHeight="42"
                    Margin="4,0,4,0"/>
            <Button Content="TOGGLE"
                    Command="{Binding SendToggleCommand}"
                    MinHeight="42"
                    Margin="8,0,0,0"/>
        </UniformGrid>

        <Grid Grid.Row="2" MaxWidth="560" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionState}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="CAN ID" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ControlIdText}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Protocol" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProtocolText}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last command" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastCommand}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Last sent" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastSentAt}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Heartbeat" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding HeartbeatProtocolText}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="PC heartbeat" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PcHeartbeatStatus}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Teensy heartbeat" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding TeensyHeartbeatStatus}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Last Teensy HB" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LastTeensyHeartbeatAtText}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Error" Margin="0,0,12,0"/>
            <TextBlock Grid.Row="9" Grid.Column="1"
                       Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource LedErrorBrush}"
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</UserControl>
