<UserControl x:Class="CanMonitor.Wpf.Transmit.TransmitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CanMonitor.Wpf.Transmit"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Teensy PWM Control"
                       Style="{StaticResource BodyTextStyle}"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Text="{Binding TelemetryProtocolText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Right"
                       Margin="18,3,0,0"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="12"
                    VerticalAlignment="Top">
                <StackPanel>
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Button Content="ON"
                                Command="{Binding SendOnCommand}"
                                MinHeight="36"
                                Margin="0,0,6,0"/>
                        <Button Content="OFF"
                                Command="{Binding SendOffCommand}"
                                MinHeight="36"
                                Margin="3,0,3,0"/>
                        <Button Content="TOGGLE"
                                Command="{Binding SendToggleCommand}"
                                MinHeight="36"
                                Margin="6,0,0,0"/>
                    </UniformGrid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionState}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CAN ID" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ControlIdText}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Protocol" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProtocolText}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Last command" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastCommand}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Last sent" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastSentAt}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Heartbeat" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding HeartbeatProtocolText}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="PC heartbeat" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PcHeartbeatStatus}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Teensy HB" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding TeensyHeartbeatStatus}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Last HB" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LastTeensyHeartbeatAtText}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Time window" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,6"/>
                        <Grid Grid.Row="9" Grid.Column="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="5"
                                    Maximum="200"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding TimeWindowMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TimeWindowText}"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Error" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0"/>
                        <TextBlock Grid.Row="10" Grid.Column="1"
                                   Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource LedErrorBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Channel1.Name}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="{Binding Channel1.MetricsText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Channel1.FrameIdText}" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Channel1.StateText}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                        <local:PulseGraphControl Grid.Row="2"
                                                 ItemsSource="{Binding Channel1.Samples}"
                                                 TraceBrush="#3DDC97"
                                                 TimeWindowMilliseconds="{Binding TimeWindowMilliseconds}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Channel2.Name}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="{Binding Channel2.MetricsText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Channel2.FrameIdText}" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Channel2.StateText}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                        <local:PulseGraphControl Grid.Row="2"
                                                 ItemsSource="{Binding Channel2.Samples}"
                                                 TraceBrush="#6AA9FF"
                                                 TimeWindowMilliseconds="{Binding TimeWindowMilliseconds}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
